{
  "name": "@sawalabs/vue-accessguard",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "main": "dist/vue-access-guard.umd.js",
  "module": "dist/vue-access-guard.es.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/vue-access-guard.es.js",
